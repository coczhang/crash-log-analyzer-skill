{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "crash-log-analyzer collection manifest",
  "type": "object",
  "required": [
    "schema_version",
    "script",
    "script_version",
    "platform",
    "collected_at",
    "redacted",
    "zip_requested",
    "files"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "script": { "type": "string", "minLength": 1 },
    "script_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "platform": { "type": "string", "enum": ["windows", "linux", "macos"] },
    "collected_at": { "type": "string", "minLength": 1 },
    "process_name": { "type": "string" },
    "process": { "type": "string" },
    "service": { "type": "string" },
    "app_path": { "type": "string" },
    "hours": { "type": ["integer", "string"] },
    "redacted": { "type": "boolean" },
    "zip_requested": { "type": "boolean" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings_file": { "type": "string" },
    "warnings_count": { "type": "integer", "minimum": 0 },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "bytes", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "bytes": { "type": "integer", "minimum": 0 },
          "sha256": { "type": ["string", "null"] }
        }
      }
    }
  }
}
